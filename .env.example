TELEGRAM_TOKEN=your_bot_token_here
WEBHOOK_URL=https://your-app.onrender.com
# Optional webhook secret (1-256 chars of A-Z a-z 0-9 _ -). A random per-boot
# secret is generated when unset.
WEBHOOK_SECRET_TOKEN=
PORT=10000
DATA_DIR=./data
# Optional. Defaults to DATA_DIR/state.db
STATE_DB_PATH=
LOG_LEVEL=INFO

# Live data (optional — prediction engine works without these)
SPORTS_API_KEY=
ODDS_API_KEY=

# LLM for narrative reasoning & Q&A (optional)
# Default: DeepSeek. Set URL+key to use OpenAI/GitHub Models/Gemini instead.
OPENAI_API_KEY=
OPENAI_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_MODEL=deepseek-chat
